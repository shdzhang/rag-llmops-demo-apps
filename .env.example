# Make a copy of this to set environment variables for local development
# cp .env.example .env

# Databricks authentication
DATABRICKS_CONFIG_PROFILE=DEFAULT

# MLflow experiment for tracing
MLFLOW_EXPERIMENT_ID=
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"

# Agent configuration
LLM_ENDPOINT=databricks-claude-sonnet-4-5
VECTOR_SEARCH_INDEX=shidong_catalog.corp_affairs.docs_index
PROMPT_NAME=shidong_catalog.corp_affairs.rag_prompt
PROMPT_ALIAS=production

# Chat UI configuration
API_PROXY=http://localhost:8000/invocations
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
